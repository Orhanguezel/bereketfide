{
  "name": "bereketfide-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "test": "bun test src/test/",
    "test:unit": "bun test src/test/dealer-register.validation.test.ts",
    "test:integration": "bun test src/test/dealer-finance.test.ts",
    "build": "bun x tsc -p tsconfig.json && bun x tsc-alias -p tsconfig.json && node scripts/fix-esm-extensions.mjs",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "start:bun": "bun dist/index.js",
    "db:seed": "bun src/db/seed/index.ts --profile=bereketfide",
    "db:seed:nodrop": "bun src/db/seed/index.ts --profile=bereketfide --no-drop",
    "db:seed:only": "bun src/db/seed/index.ts --only=",
    "db:seed:full": "bun src/db/seed/index.ts",
    "db:seed:full:nodrop": "bun src/db/seed/index.ts --no-drop",
    "db:seed:bereketfide": "bun src/db/seed/index.ts --profile=bereketfide --no-drop",
    "db:seed:bereketfide:fresh": "bun src/db/seed/index.ts --profile=bereketfide"
  },
  "dependencies": {
    "@agro/shared-backend": "workspace:*",
    "@agro/shared-types": "workspace:*",
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/jwt": "^10",
    "@fastify/multipart": "^9",
    "@fastify/mysql": "^5.0.2",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "2.0.0",
    "geoip-lite": "^1.4.10",
    "iyzipay": "^2.0.64",
    "google-auth-library": "^10.4.1",
    "mysql2": "^3.15.3",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.11",
    "pdfkit": "^0.17.2",
    "puppeteer": "^24.32.1",
    "ws": "^8.18.3",
    "zod": "3.23.8",
    "zod-to-json-schema": "3.23.2"
  },
  "devDependencies": {
    "@esbuild/linux-x64": "0.25.11",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "20",
    "@types/nodemailer": "^7.0.4",
    "@types/pdfkit": "^0.17.5",
    "bun-types": "^1.3.1",
    "esbuild": "0.25.11",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "5"
  },
  "overrides": {
    "zod-to-json-schema": "3.23.2"
  },
  "resolutions": {
    "zod-to-json-schema": "3.23.2"
  }
}
