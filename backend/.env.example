# =========================================================
# Genel
# =========================================================
PORT=8086
NODE_ENV=development
# Uretimde HTTPS: JWT cookie icin app.ts sameSite=none + secure=true (cok-origin admin/public).

# =========================================================
# DB bağlantısı
# =========================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=bereketfide
# B2B/bayi seed (314-317): backend dizininde `bun run build` sonra `bun run db:seed:bereketfide` veya `db:seed:bereketfide:fresh`

# =========================================================
# Auth / login
# =========================================================
ALLOW_TEMP_LOGIN=0
TEMP_PASSWORD=change-me

JWT_SECRET=change-me-long-random-jwt-secret
COOKIE_SECRET=change-me-long-random-cookie-secret
AUTH_ADMIN_EMAILS=admin@example.com

# Seed (db/seed/index.ts): admin ve SQL yer tutuculari
ADMIN_EMAIL=admin@example.com
ADMIN_ID=4f618a8d-6fdb-498c-898a-395d368b2193
ADMIN_PASSWORD=admin123
# Test bayi (317): bayi@example.com — ayri sifre icin; yoksa ADMIN_PASSWORD, o da yoksa admin123
BAYI_PASSWORD=admin123

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# =========================================================
# CORS  (credentials: true — tarayicinin API’ye cookie/header gonderebilmesi icin origin listesi)
# =========================================================
# Yerel: public site 3030, admin 3004 (CLAUDE.md). Virgulle ayirin; bos birakilirsa FRONTEND_URL tek origin olur.
# Uretim: Tum gercek originleri virgulle ekleyin (tarayici credentials ile API cagrisi icin sifir eksik kalmasin):
#   - public: https://www.bereketfide.com.tr ve apex https://bereketfide.com.tr (301 ile tek canonical tercih etseniz bile iki origin de istenebilir)
#   - admin panel: https://admin.bereketfide.com.tr (veya kullandiginiz alt alan)
# Yerelde 3030 + 3004 yeterli; JWT cookie cok-origin ise app tarafinda SameSite=None + Secure (bkz. ust yorum).
CORS_ORIGIN=http://localhost:3030,http://127.0.0.1:3030,http://localhost:3004,http://127.0.0.1:3004

# =========================================================
# Storage / Upload
# =========================================================
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/uploads
LOCAL_STORAGE_BASE_URL=/uploads
STORAGE_CDN_PUBLIC_BASE=
STORAGE_PUBLIC_API_BASE=http://localhost:8086

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=kompozit
CLOUDINARY_UNSIGNED_PRESET=
CLOUDINARY_UNSIGNED_UPLOAD_PRESET=

# =========================================================
# Mail / SMTP
# =========================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@example.com
SMTP_SECURE=false

# =========================================================
# URL’ler  (PORT ile ayni host; API genelde 8086)
# =========================================================
PUBLIC_URL=http://localhost:8086
FRONTEND_URL=http://localhost:3030
FRONTEND_DEFAULT_LOCALE=tr
PUBLIC_API_BASE=http://localhost:8086

# =========================================================
# Google OAuth
# =========================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =========================================================
# Browser / Audit
# =========================================================
PUPPETEER_EXECUTABLE_PATH=
AUDIT_EXCLUDE_IPS=

# =========================================================
# Kurulum / operasyon (ozet)
# =========================================================
# Monorepo kokunden (shared paket degisince veya ilk clone): bun install && bun run build:shared
# Bu backend: .env bu dosyadan uretin; ardindan bun run build
# Seed (Bereket Fide profili, 314-317 bayi/B2B dahil): src/db/seed/index.ts -> PROFILE_PREFIXES.bereketfide
#   Ornek: bun run db:seed:bereketfide  |  sifirdan: db:seed:bereketfide:fresh (prod disinda, ALLOW_DROP gerekebilir)
# Canli: CORS_ORIGIN listesini dogrulayin; giris/cerezleri tarayicide test edin (www + admin).

# =========================================================
# Canli / staging — manuel kontrol listesi (deploy sonrasi)
# =========================================================
# 1) CORS_ORIGIN: public www + apex (gerekirse ayri origin) + admin panel URL — virgul ile tam liste, bosluk yok.
# 2) FRONTEND_URL / PUBLIC_URL / PUBLIC_API_BASE: uretim URL’leri (https).
# 3) NODE_ENV=production: JWT cookie SameSite=None + Secure (app.ts); admin ve public farkli origin ise zorunlu.
# 4) Tarayici: public sitede giris (varsa) + admin giris; Application > Cookies altinda API host icin cookie set edildigini dogrulayin.
# 5) CORS preflight: tarayici konsolunda API cagrisinda CORS veya 401/403 zinciri yok.

# =========================================================
# Odeme — Iyzico / kart (ileri faz; varsayilan kapali)
# =========================================================
# Bayi siparis odemesi su an: havale (pending) + cari (paid). Kart icin once Iyzico uyeligi / anahtarlar.
# Referans implementasyon: monorepo `projects/vistaseed/backend/src/modules/orders/`
#   payment.controller.ts (initiate), payment-callback.controller.ts, `modules/wallet/` (iyzico, iyzico-sdk).
# Bereket Fide: `POST /api/v1/orders/:id/payment/iyzico/initiate` (bayi) + `POST .../orders/payment/iyzico/callback` (public).
FEATURE_IYZICO_PAYMENT=0
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Canli: https://api.iyzipay.com
# IYZICO_SUB_MERCHANT_KEY=
# (Alt bayi / pazaryeri sozlesmesi varsa; bos birakilabilir.)

# =========================================================
# Odeme — Banka Sanal POS / Tarim Karti
# Is Imece POS | Ziraat Basak | Halkbank Sanal POS
# =========================================================
# Kod hazir; saglayici bilgilerini doldurunca aktif etmek icin FEATURE_BANK_CARD_PAYMENT=1 yapin.
# Saglayici secimi: PAYMENT_CARD_PROVIDER=craftgate | nestpay_isbank | nestpay_halkbank | ziraatpay
#
# Oneri: once Craftgate sandbox ile test edin (Craftgate'e uyelik gerekmez sandbox icin),
# ardindan banka sozlesmesi sonrasi dogrudan entegrasyona gecin.

FEATURE_BANK_CARD_PAYMENT=0
PAYMENT_CARD_PROVIDER=craftgate

# --- Craftgate (tek entegrasyon — 15+ banka, sandbox hazir) ---
# Sandbox: https://sandbox-api.craftgate.io | Uretim: https://api.craftgate.io
# Sandbox API anahtarlari icin: https://craftgate.io/tr/iletisim/
# CRAFTGATE_API_KEY=
# CRAFTGATE_SECRET_KEY=
# CRAFTGATE_BASE_URL=https://sandbox-api.craftgate.io
# Canli: CRAFTGATE_BASE_URL=https://api.craftgate.io

# --- NestPay — Is Bankasi (EstV3Pos / Asseco) ---
# Tum bilgiler banka sozlesmesi + panel'den alinir:
#   - Panel: https://sanalpos.isbank.com.tr
#   - Merchant ID: Panel sag ust kose
#   - API User/Pass: Panel > Yonetim > Yeni Kullanici Ekle
#   - Store Key: Panel > Yonetim > Guvenlik Anahtari
#   - IP Whitelist: Sunucu IP'yi bankaya bildirin (zorunlu)
# NESTPAY_ISBANK_MERCHANT_ID=
# NESTPAY_ISBANK_API_USER=
# NESTPAY_ISBANK_API_PASS=
# NESTPAY_ISBANK_STORE_KEY=
# NESTPAY_ISBANK_API_URL=https://sanalpos.isbank.com.tr/fim/api
# NESTPAY_ISBANK_3D_URL=https://sanalpos.isbank.com.tr/fim/est3Dgate

# --- NestPay — Halkbank (EstV3Pos / Asseco) ---
# Panel: https://sanalpos.halkbank.com.tr
# ONEMLI: API sifresi ve Guvenlik Anahtari AYNI deger olmalidir; farkli olursa hash hatasi.
# NESTPAY_HALKBANK_MERCHANT_ID=
# NESTPAY_HALKBANK_API_USER=
# NESTPAY_HALKBANK_API_PASS=
# NESTPAY_HALKBANK_STORE_KEY=
# NESTPAY_HALKBANK_3D_URL=https://sanalpos.halkbank.com.tr/halk/est3Dgate

# --- ZiraatPay REST API v2 ---
# Dokuman: https://vpos.ziraatpay.com.tr/ziraatpay/api/v2/doc
# Test kartlari: Ziraat-VISA 4546711234567894 CVV 000 Son 12/2026 | 3D sifre: a
# ZIRAATPAY_MERCHANT=
# ZIRAATPAY_MERCHANT_USER=
# ZIRAATPAY_MERCHANT_PASSWORD=
# ZIRAATPAY_BASE_URL=https://test.ziraatpay.com.tr/ziraatpay/api/v2
# Canli: ZIRAATPAY_BASE_URL=https://vpos.ziraatpay.com.tr/ziraatpay/api/v2
