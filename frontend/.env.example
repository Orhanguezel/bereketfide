NEXT_PUBLIC_API_URL=http://localhost:8086/api/v1
NEXT_PUBLIC_SITE_URL=https://www.bereketfide.com.tr

# Bayi ağı — VistaSeed ile aynı env adı. Yerelde: cp .env.local.example .env.local ve anahtarı doldurun
# veya vistaseed/frontend/.env.local içindeki NEXT_PUBLIC_GOOGLE_MAPS_API_KEY satırını kopyalayın.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=__FILL_BROWSER_RESTRICTED_MAPS_KEY__

# Uretim: SITE_URL ve API_URL gercek domaine gore ayarlanir. Backend CORS listesinde bu origin (www + gerekirse apex) olmalidir.
# Admin panel ayri origin kullaniyorsa o da backend CORS_ORIGIN'e eklenir.

# Ana sayfa is ortagi / referans logosu bandi (GET /references). Varsayilan kapali.
# NEXT_PUBLIC_FEATURE_HOME_REFERENCES=1

# Ana sayfa katalog kartlari (GET /library?type=catalog). Varsayilan kapali.
# NEXT_PUBLIC_FEATURE_HOME_CATALOGS=1

# Ana sayfa blog / haber bantlari. Varsayilan acik; API cagrisi ve bolumu kapatmak icin:
# NEXT_PUBLIC_FEATURE_HOME_BLOG=0
# NEXT_PUBLIC_FEATURE_HOME_NEWS=0

# Footer bulten formu (POST /newsletter/subscribe). Varsayilan kapali.
# NEXT_PUBLIC_FEATURE_FOOTER_NEWSLETTER=1

# Bayi siparis detayinda Iyzico kart butonu. Backend: FEATURE_IYZICO_PAYMENT=1 + IYZICO_* anahtarlari gerekir.
# NEXT_PUBLIC_FEATURE_IYZICO_PAYMENT=1

# Bayi siparis detayinda banka kart butonu (Craftgate / NestPay / ZiraatPay).
# Backend: FEATURE_BANK_CARD_PAYMENT=1 + saglayici anahtarlari gerekir.
# NEXT_PUBLIC_FEATURE_BANK_CARD_PAYMENT=1
NEXT_PUBLIC_SITE_ID=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
SEO_MONITORING_WEBHOOK_URL=
