# Bereket Fide frontend — yerel geliştirme (kopyala: cp .env.local.example .env.local)
# VistaSeed ile aynı anahtar değişkeni: projects/vistaseed/frontend/.env.local içindeki
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY satırını buraya da ekleyebilirsiniz (tek Cloud projesi / tek tarayıcı anahtarı).

NEXT_PUBLIC_API_URL=http://localhost:8086/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3030

# Google Maps (Bayi ağı). Üretim: tarayıcı kısıtlı anahtar — bkz. vistaseed .env.production.example
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=__FILL_BROWSER_RESTRICTED_MAPS_KEY__
